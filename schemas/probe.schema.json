{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ops Probe",
  "type": "object",
  "required": [
    "status",
    "last_run_time",
    "key_checks",
    "warnings",
    "artifact_links"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "OK",
        "WARN",
        "FAIL"
      ]
    },
    "last_run_time": {
      "type": "string",
      "description": "ISO-8601 timestamp in UTC, ex: 2026-02-27T22:45:00Z"
    },
    "duration_seconds": {
      "type": [
        "number",
        "null"
      ]
    },
    "freshness": {
      "type": "object",
      "properties": {
        "max_date": {
          "type": [
            "string",
            "null"
          ],
          "description": "ISO-8601 timestamp or YYYY-MM-DD for max source data date"
        },
        "lag_seconds": {
          "type": [
            "number",
            "null"
          ]
        },
        "stale": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "row_counts": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "integer",
          "number"
        ]
      }
    },
    "schema_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "key_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "OK",
              "WARN",
              "FAIL"
            ]
          },
          "detail": {
            "type": "string"
          },
          "metric": {}
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "url"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": true
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
