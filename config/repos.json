{
  "history_retention": 40,
  "defaults": {
    "branch": "main",
    "probe_path": "ops/probe.json",
    "freshness_warn_hours": 24,
    "freshness_fail_hours": 72,
    "duration_warn_multiplier": 2.0,
    "duration_baseline_min_seconds": 5,
    "duration_baseline_min_samples": 3
  },
  "repos": [
    {
      "repo": "yt-codex/prize-alert-telegram"
    },
    {
      "repo": "yt-codex/amenities-dashboard",
      "app_url": "https://yt-codex.github.io/amenities-dashboard/web/",
      "freshness_warn_hours": 840,
      "freshness_fail_hours": 1680
    },
    {
      "repo": "yt-codex/enbloc-morning-digest"
    },
    {
      "repo": "yt-codex/sg-developers-health-monitor",
      "app_url": "https://yt-codex.github.io/sg-developers-health-monitor/index.html"
    }
  ]
}
